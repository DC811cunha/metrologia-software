# =============================================================
# SoftMeter — Variáveis de Ambiente
# Copie este arquivo para .env e ajuste os valores
# NUNCA comite o arquivo .env no repositório
# =============================================================

# Banco de dados
DB_USER=softmeter
DB_PASSWORD=softmeter123
DB_NAME=softmeter_db
DATABASE_URL=postgresql://softmeter:softmeter123@localhost:5432/softmeter_db

# JWT
JWT_SECRET=TROQUE_PARA_UM_VALOR_SECRETO_EM_PRODUCAO
JWT_EXPIRES_IN=7d

# Backend
PORT=3001
NODE_ENV=development

# Frontend
VITE_API_URL=http://localhost:3001
